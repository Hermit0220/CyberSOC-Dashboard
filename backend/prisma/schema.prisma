// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  email            String    @unique
  passwordHash     String
  role             String    @default("Guest User") // Guest User, Registered User, Security Analyst, Administrator
  status           String    @default("Active")
  createdDate      DateTime  @default(now())
  lastLogin        DateTime?
  
  securityScans    SecurityScan[]
  userActivityLogs UserActivityLog[]
}

model SecurityScan {
  id           Int      @id @default(autoincrement())
  userId       Int
  scanType     String   // e.g., "Malware Simulation", "Password Analysis"
  scanResult   String
  riskScore    Int
  timestamp    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id])
}

model NetworkEvent {
  id           Int      @id @default(autoincrement())
  attackType   String
  sourceIp     String
  targetIp     String
  severity     String
  timestamp    DateTime @default(now())
}

model ThreatFeed {
  id           Int      @id @default(autoincrement())
  category     String
  severity     String
  title        String
  description  String
  timestamp    DateTime @default(now())
}

model UserActivityLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  action       String   // e.g., "Logged in", "Password updated"
  timestamp    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
}
